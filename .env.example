# GEMINI_LLM_MODEL=gemini-1.5-flash

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=dodge_password_123

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_data

# Dataset path
DATASET_PATH=./sap-order-to-cash-dataset/sap-o2c-data

# Streamlit UI → FastAPI (base URL including /api)
API_BASE=http://127.0.0.1:8000/api
